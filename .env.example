NODE_ENV=development
PORT=3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=dpccgaming
DB_PASSWORD=replace_with_strong_password
DB_NAME=dpccgaming
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=replace_with_a_random_secret_min_32_chars

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://dpccgaming.xyz

# Paths (optional)
UPLOADS_PATH=uploads
GAMES_ROOT_PATH=games
CODE_ROOT_PATH=uploads/code
TEMP_PATH=temp

# Payment / Alipay
APP_PUBLIC_URL=https://dpccgaming.xyz
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=/www/wwwroot/dpccgaming.xyz/key/PRIVATE-RSA2048.txt
ALIPAY_PUBLIC_KEY_PATH=/www/wwwroot/dpccgaming.xyz/key/alipay_public_key.txt
# Optional fallback: inline PEM content when *_PATH is not set
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://dpccgaming.xyz/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://dpccgaming.xyz/payment
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
